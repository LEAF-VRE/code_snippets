<?xml version="1.0" encoding="UTF-8"?>
<xsl:stylesheet 
    xmlns:xsl="http://www.w3.org/1999/XSL/Transform"
    xmlns:tei="http://www.tei-c.org/ns/1.0"
    xmlns:xs="http://www.w3.org/2001/XMLSchema"
    exclude-result-prefixes="tei xs"
    version="2.0">

  <xsl:output method="xml" indent="yes" encoding="UTF-8"/>

  <!--
    Optional filename parameter.
    - If supplied by the processor (e.g. saxon -s:input.xml filename=input.xml), it is used.
    - If the processor stringifies the document first and document-uri() is empty,
      we fall back to the TEI titleStmt/title value, normalised to lowercase with
      spaces replaced by underscores.
    - If neither is available, we fall back to the literal string "document".
  -->
  <xsl:param name="filename" as="xs:string?" select="()"/>

  <xsl:variable name="basename" as="xs:string">
    <xsl:choose>
      <!-- 1. Explicit filename parameter was passed in -->
      <xsl:when test="normalize-space($filename) != ''">
        <xsl:value-of select="replace(normalize-space($filename), '\.[^.]+$', '')"/>
      </xsl:when>
      <!-- 2. Try document-uri() (works in file-based Saxon invocations) -->
      <xsl:when test="normalize-space(document-uri(/)) != ''">
        <xsl:value-of select="replace(tokenize(document-uri(/), '/')[last()], '\.[^.]+$', '')"/>
      </xsl:when>
      <!-- 3. Fall back to TEI titleStmt/title — try both namespaced and no-namespace -->
      <xsl:when test="normalize-space((/tei:TEI/tei:teiHeader/tei:fileDesc/tei:titleStmt/tei:title[1]
                                      | /TEI/teiHeader/fileDesc/titleStmt/title[1])[1]) != ''">
        <xsl:variable name="raw-title" as="xs:string"
                      select="normalize-space((/tei:TEI/tei:teiHeader/tei:fileDesc/tei:titleStmt/tei:title[1]
                                              | /TEI/teiHeader/fileDesc/titleStmt/title[1])[1])"/>
        <!-- lowercase, collapse inner spaces, replace spaces with underscores,
             strip any characters that are illegal in XML NCNames               -->
        <xsl:value-of select="replace(
                                replace(
                                  lower-case(normalize-space($raw-title)),
                                  '\s+', '_'),
                                '[^a-z0-9_\-.]', '')"/>
      </xsl:when>
      <!-- 4. Hard fallback -->
      <xsl:otherwise>document</xsl:otherwise>
    </xsl:choose>
  </xsl:variable>

  <!-- ============================================================
       Identity transform: copy everything as-is
       ============================================================ -->
  <xsl:template match="@* | node()">
    <xsl:copy>
      <xsl:apply-templates select="@* | node()"/>
    </xsl:copy>
  </xsl:template>

  <!-- ============================================================
       div elements (TEI-namespaced or no-namespace)
       ============================================================ -->
  <xsl:template match="tei:div | div">
    <xsl:copy>
      <xsl:choose>
        <xsl:when test="@xml:id">
          <!-- Already has an xml:id — preserve everything untouched -->
          <xsl:apply-templates select="@* | node()"/>
        </xsl:when>
        <xsl:otherwise>
          <xsl:variable name="n" as="xs:integer"
                        select="count(preceding::tei:div[not(@xml:id)] |
                                      preceding::div[not(@xml:id)]) + 1"/>
          <xsl:attribute name="xml:id"
                         select="concat($basename, '_div_', $n)"/>
          <xsl:apply-templates select="@* | node()"/>
        </xsl:otherwise>
      </xsl:choose>
    </xsl:copy>
  </xsl:template>

  <!-- ============================================================
       p elements (TEI-namespaced or no-namespace)
       ============================================================ -->
  <xsl:template match="tei:p | p">
    <xsl:copy>
      <xsl:choose>
        <xsl:when test="@xml:id">
          <!-- Already has an xml:id — preserve everything untouched -->
          <xsl:apply-templates select="@* | node()"/>
        </xsl:when>
        <xsl:otherwise>
          <xsl:variable name="n" as="xs:integer"
                        select="count(preceding::tei:p[not(@xml:id)] |
                                      preceding::p[not(@xml:id)]) + 1"/>
          <xsl:attribute name="xml:id"
                         select="concat($basename, '_p_', $n)"/>
          <xsl:apply-templates select="@* | node()"/>
        </xsl:otherwise>
      </xsl:choose>
    </xsl:copy>
  </xsl:template>

</xsl:stylesheet>
